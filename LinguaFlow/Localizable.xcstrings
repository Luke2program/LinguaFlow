    "Tap Speak, say the answer, then tap Use speech.": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Tippe auf Sprechen, sage die Antwort, dann tippe auf Sprache verwenden." } },
        "es": { "stringUnit": { "state": "translated", "value": "Toca Hablar, di la respuesta, luego toca Usar voz." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Touchez Parler, dites la réponse, puis touchez Utiliser la parole." } },
        "it": { "stringUnit": { "state": "translated", "value": "Tocca Parla, di la risposta, poi tocca Usa voce." } },
        "pt": { "stringUnit": { "state": "translated", "value": "Toque em Falar, diga a resposta, depois toque em Usar voz." } },
        "nl": { "stringUnit": { "state": "translated", "value": "Tik op Spreek, zeg het antwoord, tik dan op Gebruik spraak." } },
        "pl": { "stringUnit": { "state": "translated", "value": "Dotknij Mów, wypowiedz odpowiedź, następnie dotknij Użyj mowy." } },
        "ru": { "stringUnit": { "state": "translated", "value": "Нажмите Говорить, произнесите ответ, затем нажмите Использовать речь." } }
      }
    },
