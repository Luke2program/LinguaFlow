      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Sprache verwenden" } },
        "es": { "stringUnit": { "state": "translated", "value": "Usar voz" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Utiliser la parole" } },
        "it": { "stringUnit": { "state": "translated", "value": "Usa voce" } },
